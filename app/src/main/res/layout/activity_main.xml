<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbarAlwaysDrawVerticalTrack="true"
    android:scrollbarStyle="insideInset">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        android:gravity="top"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16pt"
            android:layout_marginBottom="24dp"
            android:gravity="start"
            android:maxLines="20"
            android:padding="8dp"

            android:text="@string/main_setup_instructions"
            android:textAlignment="center"
            android:textColor="#777777"
            android:textSize="16sp"
            android:visibility="visible"
            tools:ignore="RtlCompat" />

        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#111111"
            android:padding="16dp"
            android:text="@string/main_btn_configure_accessibility"
            android:textColor="#999999"
            android:textSize="16sp"
            android:visibility="visible" />

        <Button
            android:id="@+id/btn_ptt_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#111111"
            android:padding="16dp"
            android:text="@string/main_btn_configure_ptt_key"
            android:textColor="#999999"
            android:textSize="16sp"
            android:visibility="visible" />

        <Button
            android:id="@+id/btn_programmable_keys"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#111111"
            android:padding="16dp"
            android:text="@string/main_configure_programmable_keys"
            android:textColor="#999999"
            android:textSize="16sp"
            android:visibility="visible" />


    </LinearLayout>

</ScrollView>
